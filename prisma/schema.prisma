// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Payload ke defaults ke mutabiq modified model
model Todo {
  id        Int      @id @default(autoincrement()) // Payload default integer ID use karta hai
  userId    String   @map("user_id")               // Payload table me 'user_id' banaye ga, Prisma me 'userId' hi rahay ga
  title     String
  completed Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") // Payload ke timestamps se mapping
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("todo") // Payload table ka naam lowercase 'todo' rakhta hai
}